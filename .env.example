# Django Infrastructure
DJANGO_SECRET_KEY=generate-a-secure-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,devscores.vercel.app

# Database Options
# For Local Docker, use: postgresql://devscore:devscore_password@db:5432/devscore
# For Production, use your Neon/Postgres connection string
DATABASE_URL=postgresql://devscore:devscore_password@db:5432/devscore

# GitHub OAuth (Create different apps for Local and Production)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Security
# Generate FERNET_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_encryption_key

# AI Integration
GROQ_API_KEY=your_groq_api_key

# Pipeline tuning
ANALYZE_MAX_REPOS_PER_RUN=120
